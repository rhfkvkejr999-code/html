type Props = {
  cards: { title: string; value: string; sub: string; color: string }[];
};

export default function DashboardCards({ cards }: Props) {
  return (
    <div style={{ display: 'grid', gridTemplateColumns: 'repeat(4, minmax(0, 1fr))', gap: 16 }}>
      {cards.map((card) => (
        <div
          key={card.title}
          style={{
            background: 'white',
            borderRadius: 18,
            padding: 20,
            border: '1px solid #e5e7eb',
            boxShadow: '0 10px 24px rgba(15, 23, 42, 0.06)',
            borderTop: `6px solid ${card.color}`,
          }}
        >
          <div style={{ fontSize: 14, color: '#6b7280', marginBottom: 8 }}>{card.title}</div>
          <div style={{ fontSize: 30, fontWeight: 800, color: '#111827' }}>{card.value}</div>
          <div style={{ fontSize: 13, color: '#6b7280', marginTop: 8 }}>{card.sub}</div>
        </div>
      ))}
    </div>
  );
}
